			<rectangle radius="14">
				<reportElement mode="Opaque" x="20" y="128" width="515" height="78" backcolor="#F7FAFC" uuid="f92d60c3-fdb3-4427-a28d-f486ef6db761"/>
				<graphicElement>
					<pen lineWidth="0.5" lineColor="#C7D7E5"/>
