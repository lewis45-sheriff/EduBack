	<!-- Parameters -->
	<parameter name="studentID" class="java.lang.Long"/>
	<parameter name="gradeId" class="java.lang.Long"/>
	<parameter name="termID" class="java.lang.String"/>
	<parameter name="year" class="java.lang.Long"/>
	<parameter name="Logo" class="java.lang.String"/>
	<parameter name="SchoolName" class="java.lang.String">
		<defaultValueExpression><![CDATA["EXCELLENCE ACADEMY"]]></defaultValueExpression>
	</parameter>
	<parameter name="SchoolMotto" class="java.lang.String">
		<defaultValueExpression><![CDATA["Nurturing Minds, Building Futures"]]></defaultValueExpression>
	</parameter>
	<parameter name="SchoolContact" class="java.lang.String">
		<defaultValueExpression><![CDATA["Tel: (123) 456-7890 | Email: info@excellenceacademy.edu"]]></defaultValueExpression>
	</parameter>

	<!-- Query -->
	<queryString language="SQL">
		<![CDATA[
        SELECT
            subject.id AS examSubjectId,
            subject.subject_code AS examSubjectCode,
            subject.subject_name AS examSubjectName,
            sScore.student_id AS examStudentId,
            s.admission_number AS studentAdmissionNumber,
            CONCAT_WS(' ', s.first_name, s.last_name) AS studentFullName,
            CAST(MAX(sScore.year) AS CHAR) AS examYear,
            sScore.grade_id AS examGradeId,
            g.name AS examGradeName,
            MAX(sScore.term) AS examTermName,
            GROUP_CONCAT(
                CONCAT(eType.name, ': ', ROUND(sScore.exam_score, 0))
                ORDER BY eType.id
                SEPARATOR ' | '
            ) AS examBreakdown,
            ROUND(AVG(sScore.exam_score), 1) AS examAverageScore,
            CASE
                WHEN AVG(sScore.exam_score) >= 80 THEN 'Exceeding Expectations'
                WHEN AVG(sScore.exam_score) >= 65 THEN 'Meeting Expectations'
                WHEN AVG(sScore.exam_score) >= 50 THEN 'Approaching Expectations'
                ELSE 'Below Expectations'
            END AS examScoreRemarks
        FROM students_score AS sScore
        JOIN grade AS g ON g.id = sScore.grade_id
        JOIN student AS s ON sScore.student_id = s.id
        JOIN academic_subject AS subject ON sScore.academic_subject_id = subject.id
        JOIN exam_type AS eType ON sScore.exam_type_id = eType.id
        WHERE
            sScore.student_id = $P{studentID}
            AND sScore.grade_id = $P{gradeId}
            AND sScore.term = $P{termID}
            AND sScore.year = $P{year}
        GROUP BY
            subject.id,
            subject.subject_code,
            subject.subject_name,
            sScore.student_id,
            s.admission_number,
            s.first_name,
            s.last_name,
            sScore.grade_id,
            g.name
        ORDER BY subject.subject_name ASC
        ]]>
	</queryString>

	<!-- Fields -->
	<field name="studentFullName" class="java.lang.String"/>
	<field name="examGradeName" class="java.lang.String"/>
	<field name="examTermName" class="java.lang.String"/>
	<field name="examYear" class="java.lang.String"/>
	<field name="studentAdmissionNumber" class="java.lang.String"/>
	<field name="examSubjectName" class="java.lang.String"/>
	<field name="examSubjectCode" class="java.lang.String"/>
	<field name="examBreakdown" class="java.lang.String"/>
	<field name="examAverageScore" class="java.lang.Double"/>
	<field name="examScoreRemarks" class="java.lang.String"/>
	<variable name="OverallAverage" class="java.lang.Double" calculation="Average">
