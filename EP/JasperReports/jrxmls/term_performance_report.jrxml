			<textField evaluationTime="Report" textAdjust="StretchHeight" isBlankWhenNull="true">
				<reportElement x="16" y="114" width="523" height="40" forecolor="#16324F" uuid="bb788e41-222f-42d2-b440-40ca1f851ec3"/>
				<textElement verticalAlignment="Top">
					<font fontName="Arial" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[
					$V{OverallAverage} == null
						? "No teacher comment is available because no assessment records were found."
						: ($V{OverallAverage}.doubleValue() >= 80
							? "Excellent performance this term. The learner has shown strong understanding across subjects. Keep up the consistency and continue challenging yourself."
							: ($V{OverallAverage}.doubleValue() >= 65
								? "Very good performance this term. The learner is progressing well and should keep revising consistently to move strong scores into outstanding ones."
								: ($V{OverallAverage}.doubleValue() >= 50
									? "There is steady progress this term. More practice, revision, and class participation will help improve overall performance."
									: "The learner needs additional support next term. Regular practice, guided revision, and close follow-up will help build confidence and improve results.")))
				]]></textFieldExpression>
			</textField>

