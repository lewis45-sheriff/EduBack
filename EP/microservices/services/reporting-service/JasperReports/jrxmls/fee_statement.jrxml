        <defaultValueExpression><![CDATA["BURETI JUNIOR ACADEMY"]]></defaultValueExpression>
    </parameter>
    <parameter name="SchoolMotto" class="java.lang.String">
        <defaultValueExpression><![CDATA["Nurturing Minds, Building Futures"]]></defaultValueExpression>
    </parameter>
    <parameter name="SchoolContact" class="java.lang.String">
        <defaultValueExpression><![CDATA["Tel: 0791861308 | Email: info@excellenceacademy.edu"]]></defaultValueExpression>
    </parameter>

    <!-- Load from finance first so balances still render even when there are no payments -->
    <queryString language="SQL">
        <![CDATA[
        SELECT
            f.student_id AS studentId,
            CONCAT_WS(' ', s.first_name, s.last_name) AS sName,
            s.admission_number AS admNo,
            ft.reference AS rNo,
            ft.transaction_date AS tDate,
            ft.amount AS Amount,
            ft.payment_method AS paymentMode,
            f.total_fee_amount AS currFee,
            f.paid_amount AS totalPaid,
            f.balance AS totalBalance,
            f.term AS currTerm,
            f.year AS currTermYear,
            (SELECT COALESCE(SUM(CASE WHEN f2.balance > 0 THEN f2.balance ELSE 0 END), 0)
             FROM finance f2
             WHERE f2.student_id = f.student_id
               AND (
                    f2.year < f.year
                    OR (
                        f2.year = f.year
                        AND CASE f2.term
                                WHEN 'TERM_1' THEN 1
                                WHEN 'TERM_2' THEN 2
                                WHEN 'TERM_3' THEN 3
                                ELSE 99
                            END
                            < CASE f.term
                                WHEN 'TERM_1' THEN 1
                                WHEN 'TERM_2' THEN 2
                                WHEN 'TERM_3' THEN 3
                                ELSE 99
                              END
                    )
               )
            ) AS balanceForward
        FROM finance f
        JOIN student s ON s.id = f.student_id
        LEFT JOIN finance_transactions ft ON ft.student_id = f.student_id
            AND ft.term = f.term
            AND ft.year = f.year
            AND ft.transaction_type = 'INCOME'
        WHERE f.student_id = $P{studentID}
          AND f.term = $P{termID}
          AND f.year = $P{year}
        ORDER BY ft.transaction_date, ft.id
        ]]>
    </queryString>

    <field name="sName" class="java.lang.String"/>
    <field name="admNo" class="java.lang.String"/>
    <field name="currFee" class="java.math.BigDecimal"/>
    <field name="currTerm" class="java.lang.String"/>
    <field name="currTermYear" class="java.lang.Integer"/>
    <field name="rNo" class="java.lang.String"/>
    <field name="tDate" class="java.sql.Date"/>
