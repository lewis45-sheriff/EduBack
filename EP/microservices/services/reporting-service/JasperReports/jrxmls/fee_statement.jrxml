                </textElement>
                <textFieldExpression><![CDATA[
                    $F{totalBalance} == null ? "No Data" :
                    ($F{totalBalance}.compareTo(java.math.BigDecimal.ZERO) > 0 ? "Outstanding" :
                    ($F{totalBalance}.compareTo(java.math.BigDecimal.ZERO) < 0 ? "Credit Balance" : "Cleared"))
                ]]></textFieldExpression>
            </textField>

            <rectangle radius="12">
                <reportElement mode="Opaque" x="0" y="80" width="555" height="86" backcolor="#F7FAFC" uuid="3c01ec79-a4eb-4929-b58e-4f5c9f69ed37"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#C7D7E5"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement style="SectionHeader" x="16" y="92" width="220" height="18" uuid="4456bd54-0914-4048-b6c4-4f31b45b6c06"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[ACCOUNTS OFFICE REMARKS]]></text>
            </staticText>

            <textField evaluationTime="Report" textAdjust="StretchHeight" isBlankWhenNull="true">
                <reportElement x="16" y="114" width="523" height="40" forecolor="#16324F" uuid="2b8f7f12-2947-436c-8223-126eea9fd42e"/>
                <textElement verticalAlignment="Top">
                    <font fontName="Arial" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    $F{totalBalance} == null
                        ? "No fee record is available for the selected term."
                        : ($F{totalBalance}.compareTo(java.math.BigDecimal.ZERO) == 0
                            ? "The student's fee account is fully cleared for the selected term. Keep this statement for your records."
                            : ($F{totalBalance}.compareTo(java.math.BigDecimal.ZERO) < 0
                                ? "The student's account has a credit balance for this term. Please confirm with the accounts office how the excess payment should be carried forward."
                                : ($V{PaymentCount} == null || $V{PaymentCount}.intValue() == 0
                                    ? "No payment has been posted for this term yet. Please liaise with the accounts office to clear the outstanding balance before the close of term."
                                    : "Payments have been posted for this term. Please clear the remaining balance and contact the accounts office if you need a payment plan or reconciliation.")))
                ]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="16" y="178" width="170" height="1" uuid="5b154f8b-a82e-4825-9e1c-2781810f1e3e"/>
                <graphicElement>
                    <pen lineWidth="0.8" lineColor="#537188"/>
                </graphicElement>
            </line>
            <staticText>
                <reportElement x="16" y="180" width="170" height="12" forecolor="#537188" uuid="f5a9c0a1-3bd8-46cb-9c0e-6b2fb25e01d0"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Accounts Office]]></text>
            </staticText>
        </band>
    </summary>

